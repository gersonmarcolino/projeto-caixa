# --- Conexão com a API ---
API_URL=http://127.0.0.1:8000
AGENT_EMAIL=admin@teste.com
AGENT_PASSWORD=admin123

# --- Comportamento ---
POLL_INTERVAL=2
STORE_NAME=Cafeteria
RECEIPT_WIDTH=32

# --- Impressora ---
# console = imprime no terminal (padrão, para testes sem impressora)
# usb | network | serial = impressora física (precisa python-escpos instalado)
PRINTER_TYPE=console

# USB (ex.: Epson costuma ser 04b8/0202) — valores em hexadecimal
# USB_VENDOR_ID=04b8
# USB_PRODUCT_ID=0202

# Rede
# PRINTER_HOST=192.168.0.100
# PRINTER_PORT=9100

# Serial
# SERIAL_PORT=COM3
# SERIAL_BAUDRATE=9600
